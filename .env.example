# Shinybeez Environment Variables
# Copy to .env and adjust values as needed.
# See config.yml for full details and defaults.

# ── App Configuration ────────────────────────
# Config profile: default | development | production | shinyapps | shinyproxy
R_CONFIG_ACTIVE=default

# Logging level: DEBUG | INFO | WARN | ERROR
RHINO_LOG_LEVEL=INFO

# ── Google Analytics ─────────────────────────
GA_ENABLED=false
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Telemetry ────────────────────────────────
TELEMETRY_ENABLED=false
# Storage backend: sqlite | postgresql
TELEMETRY_STORAGE=sqlite
# SQLite path (relative to app root)
TELEMETRY_DB_PATH=data/telemetry.sqlite

# PostgreSQL (used when TELEMETRY_STORAGE=postgresql)
# TELEMETRY_DB_HOST=localhost
# TELEMETRY_DB_PORT=5432
# TELEMETRY_DB_NAME=shinybeez_telemetry
# TELEMETRY_DB_USER=postgres
# TELEMETRY_DB_PASSWORD=

# ── Docker Hub (CI/CD only) ──────────────────
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=
